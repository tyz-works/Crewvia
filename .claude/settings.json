{
  "permissions": {
    "allow": [
      "Bash(tmux:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(./scripts/:*)",
      "Bash(./bin/:*)",
      "Bash(awk:*)",
      "Bash(mv queue/tasks/:*)",
      "Bash(bash scripts/:*)",
      "Bash(chmod +x scripts/:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(gh api repos/*)",
      "Bash(gh pr create:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(bun test:*)",
      "Bash(pytest:*)",
      "Bash(tsc --noEmit:*)",
      "Bash(eslint:*)",
      "Bash(prettier --check:*)",
      "Bash(./scripts/plan.sh:*)",
      "Bash(bash scripts/plan.sh:*)",
      "Bash(bash hooks/:*)",
      "Bash(./hooks/:*)",
      "Bash(python3 scripts/:*)",
      "Bash(shasum:*)",
      "Bash(mktemp:*)",
      "Bash(cp .claude/settings.json:*)",
      "Bash(./hooks/notification.sh:*)",
      "Bash(bash hooks/notification.sh:*)",
      "Bash(chmod +x ./hooks/notification.sh)",
      "Bash(chmod +x hooks/notification.sh)",
      "Bash(vercel logs:*)",
      "Bash(vercel ls:*)",
      "Bash(vercel inspect:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/tyz/workspace/crewvia/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/tyz/workspace/crewvia/hooks/post-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/tyz/workspace/crewvia/hooks/sh_perm_manager.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/tyz/workspace/crewvia/hooks/notification.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
