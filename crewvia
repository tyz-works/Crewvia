#!/usr/bin/env bash
set -euo pipefail

# crewvia — One-command launcher for the crewvia multi-agent system
#
# Usage:
#   ./crewvia                        # Orchestrator を tmux モードで起動
#   ./crewvia worker code typescript  # Worker を手動起動
#   ./crewvia status                 # 稼働中の mission/worker を表示

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/config/crewvia.yaml"
TOKEN_FILE="${SCRIPT_DIR}/config/.taskvia-token"

# --- config から設定を読み込む ---
read_config() {
  local key="$1" default="${2:-}"
  if [[ -f "$CONFIG_FILE" ]]; then
    local val
    val=$(grep -E "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//' | sed 's/[[:space:]]*#.*//' | tr -d '"' | tr -d "'")
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  echo "$default"
}

# --- CLI フラグ解析（--taskvia / --no-taskvia） ---
FLAG_TASKVIA=""
FLAG_NO_TASKVIA=""
REMAINING_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --taskvia)    FLAG_TASKVIA="true" ;;
    --no-taskvia) FLAG_NO_TASKVIA="true" ;;
    *)            REMAINING_ARGS+=("$arg") ;;
  esac
done
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

# --- CREWVIA_TASKVIA 決定（env > flag > config > ask） ---
if [[ -z "${CREWVIA_TASKVIA:-}" ]]; then
  if [[ "$FLAG_TASKVIA" == "true" ]]; then
    export CREWVIA_TASKVIA="enabled"
  elif [[ "$FLAG_NO_TASKVIA" == "true" ]]; then
    export CREWVIA_TASKVIA="disabled"
  else
    TASKVIA_FROM_CONFIG="$(read_config taskvia "ask")"
    export CREWVIA_TASKVIA="$TASKVIA_FROM_CONFIG"
  fi
fi

# ask モードの対話処理（crewvia 起動時に解決する）
if [[ "${CREWVIA_TASKVIA}" == "ask" ]]; then
  if [[ -e /dev/tty ]]; then
    echo ""
    echo "[crewvia] Taskvia 承認フローを使用しますか？"
    echo "          Y = 有効（WebUI でツール承認・ログ投稿）"
    echo "          n = 無効（スタンドアロンモード、承認なし）"
    printf "> [Y/n]: "
    read -r TASKVIA_CHOICE </dev/tty || TASKVIA_CHOICE=""
    case "$TASKVIA_CHOICE" in
      n|N|no|No|NO)
        export CREWVIA_TASKVIA="disabled"
        echo "[crewvia] Taskvia 連携を無効にします（スタンドアロンモード）。"
        ;;
      *)
        export CREWVIA_TASKVIA="enabled"
        echo "[crewvia] Taskvia 承認フローを有効にします。"
        ;;
    esac
  else
    # 非対話環境: enabled にフォールバック（トークン未設定なら既存の standalone 動作に委譲）
    export CREWVIA_TASKVIA="enabled"
  fi
fi

# --- Taskvia トークンを読み込む（disabled 時はスキップ） ---
if [[ "${CREWVIA_TASKVIA}" != "disabled" ]]; then
  if [[ -z "${TASKVIA_TOKEN:-}" ]] && [[ -f "$TOKEN_FILE" ]]; then
    TASKVIA_TOKEN="$(tr -d '[:space:]' < "$TOKEN_FILE")"
    export TASKVIA_TOKEN
  fi
fi

# --- Taskvia URL ---
if [[ -z "${TASKVIA_URL:-}" ]]; then
  export TASKVIA_URL="$(read_config taskvia_url "https://taskvia.vercel.app")"
fi

# --- 起動モード ---
if [[ -z "${CREWVIA_TMUX:-}" ]]; then
  MODE="$(read_config mode "tmux")"
  case "$MODE" in
    tmux)  export CREWVIA_TMUX=1 ;;
    inline) export CREWVIA_TMUX=0 ;;
    *)
      echo "[crewvia] WARNING: 不明な mode '$MODE'。tmux で起動します。" >&2
      export CREWVIA_TMUX=1
      ;;
  esac
fi

# --- サブコマンド ---
SUBCMD="${1:-director}"

case "$SUBCMD" in
  status)
    exec bash "${SCRIPT_DIR}/scripts/plan.sh" status "${@:2}"
    ;;
  worker)
    shift
    exec bash "${SCRIPT_DIR}/scripts/start.sh" worker "$@"
    ;;
  director|orchestrator|start)
    exec bash "${SCRIPT_DIR}/scripts/start.sh" director
    ;;
  help|-h|--help)
    cat <<HELP
crewvia — マルチエージェントシステム ランチャー

Usage:
  ./crewvia [--taskvia|--no-taskvia] [subcommand] [options]

Subcommands:
  (none)                            Director を起動 (デフォルト)
  worker <skill> ...                Worker を起動
  status [--mission slug]           ミッション状態を表示

Flags:
  --taskvia                         Taskvia 承認フローを有効化
  --no-taskvia                      Taskvia 連携を無効化（スタンドアロン）

Taskvia フラグ:
  --taskvia      承認フロー有効（WebUI でツール承認・ログ投稿）
  --no-taskvia   スタンドアロンモード（承認なし、トークン不要）
  ※ config/crewvia.yaml の taskvia: 設定より優先される

Config:  config/crewvia.yaml
Token:   config/.taskvia-token  (1行にトークンを書く、gitignore 済み)

Environment variables (config より優先):
  CREWVIA_TASKVIA=enabled|disabled|ask  Taskvia 連携モード（最優先）
  CREWVIA_TMUX=1|0                      起動モード
  TASKVIA_TOKEN=sk-...                  API トークン
  TASKVIA_URL=https://...               Taskvia URL
HELP
    ;;
  *)
    echo "[crewvia] Unknown command: $SUBCMD" >&2
    echo "  Run './crewvia help' for usage." >&2
    exit 1
    ;;
esac
